# Dev: leave VITE_API_BASE_URL unset so the app calls /api on the Vite dev server,
# which proxies to the gateway (see vite.config.js, default http://127.0.0.1:18080).
# VITE_PROXY_TARGET=http://127.0.0.1:18080

# Production / special setups: full gateway URL (trailing slash optional).
# VITE_API_BASE_URL=http://localhost:18080
